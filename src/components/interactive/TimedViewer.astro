---
import TimedViewerReact from './TimedViewer.tsx';

interface Props {
  src: string;
  alt: string;
  credit: string;
  duration?: number;
  prompts?: string[];
  intro?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const props = {
  ...Astro.props,
  src: Astro.props.src.startsWith('/') ? base + Astro.props.src : Astro.props.src,
};
---

<TimedViewerReact {...props} client:visible />
