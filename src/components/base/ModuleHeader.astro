---
import type { CollectionEntry } from 'astro:content';

interface Props {
  module: CollectionEntry<'modules'>;
  themeCount: number;
}

const { module, themeCount } = Astro.props;
const { order, title, intro } = module.data;
const orderLabel = String(order).padStart(2, '0');
---

<header class="module-header">
  <div class="module-header__main">
    <p class="module-header__number">{orderLabel}</p>
    <div class="module-header__text">
      <h2 class="module-header__title">{title}</h2>
      <p class="module-header__intro">{intro}</p>
    </div>
  </div>
  <p class="module-header__count">{themeCount} hoofdstukken</p>
</header>

<style>
  .module-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .module-header__main {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .module-header__number {
    font-family: var(--font-mono);
    font-size: var(--step-3);
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1;
    flex-shrink: 0;
    padding-top: 0.1em;
  }

  .module-header__title {
    font-family: var(--font-serif);
    font-size: var(--step-3);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.15;
  }

  .module-header__intro {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    max-width: 55ch;
  }

  .module-header__count {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-whisper);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.4em;
  }

  @media (max-width: 640px) {
    .module-header {
      flex-direction: column;
    }

    .module-header__count {
      order: 3;
    }
  }
</style>
