---
interface Props {
  id: string;
  type?: 'figure' | 'video';
  icon?: string;
  label?: string;
}

const { id, type = 'figure', icon, label } = Astro.props;

const ICONS: Record<string, string> = {
  image: `<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>`,
  'play-circle': `<circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>`,
  video: `<path d="m22 8-6 4 6 4V8z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/>`,
  audio: `<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>`,
};

let svgInner: string;
if (type === 'video') {
  svgInner = ICONS['play-circle'];
} else {
  const iconName = (icon ?? 'lucide:image').replace(/^lucide:/, '');
  svgInner = ICONS[iconName] ?? ICONS.image;
}

const ariaLabel = type === 'video'
  ? `Bekijk video: ${label ?? id}`
  : `Bekijk figuur: ${label ?? id}`;
---

<button
  class="figure-link"
  type="button"
  data-figure-id={id}
  data-figure-type={type}
  aria-label={ariaLabel}
><span class="figure-link__bracket">[</span><svg
    class="figure-link__icon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    set:html={svgInner}
  ></svg> <slot /><span class="figure-link__bracket">]</span></button>

<style>
  .figure-link {
    display: inline;
    background: none;
    border: none;
    border-bottom: 1px dashed rgba(237, 75, 158, 0.4);
    padding: 0;
    color: var(--color-accent);
    cursor: pointer;
    white-space: nowrap;
    font: inherit;
    line-height: inherit;
  }

  .figure-link:hover {
    border-bottom-color: var(--color-accent);
  }

  .figure-link__bracket {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: rgba(237, 75, 158, 0.6);
  }

  .figure-link__icon {
    width: 0.75em;
    height: 0.75em;
    margin: 0 0.25em;
    vertical-align: -0.05em;
    stroke: currentColor;
  }
</style>
