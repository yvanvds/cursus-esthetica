---
import '../styles/global.css';
import SiteHeader from '../components/base/SiteHeader.astro';
import SiteFooter from '../components/base/SiteFooter.astro';
import Lightbox from '../components/base/Lightbox.astro';
import VideoOverlay from '../components/base/VideoOverlay.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cursus Esthetica',
  description = 'Veertien manieren van kijken.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <link
      rel="preload"
      href={`${base}fonts/fraunces-latin-wght-normal.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={`${base}fonts/inter-latin-wght-normal.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    <slot name="head" />
    <style set:html={`
      @font-face {
        font-family: 'Fraunces';
        src: url('${base}fonts/fraunces-latin-wght-normal.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Fraunces';
        src: url('${base}fonts/fraunces-latin-wght-italic.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-style: italic;
        font-display: swap;
      }
      @font-face {
        font-family: 'Inter';
        src: url('${base}fonts/inter-latin-wght-normal.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'JetBrains Mono';
        src: url('${base}fonts/jetbrains-mono-latin-wght-normal.woff2') format('woff2-variations');
        font-weight: 100 800;
        font-style: normal;
        font-display: swap;
      }
    `} />
  </head>
  <body>
    <SiteHeader />
    <main class="page-content">
      <slot />
    </main>
    <SiteFooter />
    <Lightbox />
    <VideoOverlay />
  </body>
</html>

<style>
  .page-content {
    padding: var(--space-sm);
    max-width: 1080px;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .page-content {
      padding: var(--space-md);
      max-width: 720px;
    }
  }

  @media (min-width: 1024px) {
    .page-content {
      padding-inline: var(--space-lg);
      max-width: 1080px;
    }
  }
</style>
